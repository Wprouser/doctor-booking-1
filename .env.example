# Neon Postgres connection string (Project → Connect → copy the pooled connection string)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Port the Express server listens on
PORT=3001

# Random secret used by Better Auth to sign sessions — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=

# The public URL the app is served from (matches the origin the browser calls).
# In dev with `npm run dev` this is the Vite URL; in production, your deployed URL.
BETTER_AUTH_URL=http://localhost:5173
